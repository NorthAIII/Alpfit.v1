# Alpfit staging environment template.
#
# Copy to .env.staging ON THE SERVER (/opt/alpfit/_ops/staging/.env.staging),
# chmod 600, owner deploy:deploy. This .example file ships in the repo as a
# placeholder; the real .env.staging is never committed.
#
# Validated on backend boot by `backend/src/config/env.ts` (zod schema).

# ─── Application ─────────────────────────────────────────────────────────
NODE_ENV=staging
APP_ENV=staging-tr
PORT=3000

# ─── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Postgres (alpfit-postgres container) ────────────────────────────────
# These three feed both the postgres service env AND the backend DATABASE_URL.
POSTGRES_USER=alpfit
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=alpfit
DATABASE_URL=postgresql://alpfit:replace-with-a-long-random-password@alpfit-postgres:5432/alpfit

# ─── Redis (alpfit-redis container) ──────────────────────────────────────
REDIS_URL=redis://alpfit-redis:6379

# ─── JWT secrets (32+ chars each; rotate independently) ──────────────────
# Generate with:  openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-at-least-32-character-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret-too

# ─── KVKK retention purge cron (TASK-1.15) ───────────────────────────────
# Bearer token for POST /admin/internal/retention-purge — host crontab calls
# this daily. Same token goes into /opt/alpfit/_ops/staging/retention-cron.env
# on the VPS. See _dev/docs/staging-retention-cron.md.
# Also guards GET /internal/dev-otp/:phoneE164 (TASK-1.17). On staging this
# endpoint stays enabled (NODE_ENV=staging != production) for dev-device OTP
# lookup; in production it is hard-404.
# Generate with:  openssl rand -hex 32
ADMIN_INTERNAL_TOKEN=replace-with-at-least-32-character-random-secret

# ─── SMS provider (TASK-1.17) ────────────────────────────────────────────
# Staging uses the mock driver: OTP lands in dev_otp_log instead of a real
# SMS. Switch to `live` only at Yakın 5 once the real provider is wired.
SMS_PROVIDER=mock
