// Alpfit backend — Prisma 7 schema
// New `prisma-client` generator (ESM-first, Rust-free WASM compiler).
// Runtime adapter (`@prisma/adapter-pg`) is wired in src/db/prisma.ts.
// Datasource URL is supplied by prisma.config.ts at CLI time and by the
// adapter at runtime — no `url` line here on purpose.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================================================================
// TASK-1.13 — 3 rol veri modeli (Member + Trainer + Gym Owner)
// =====================================================================
// Pazarlık konusu olmayan karar (ILKELER §Pazarlık Konusu Olmayanlar §1):
// v1'de UI yalnızca Member + Trainer'ı gösterir; Gym Owner için model
// **şimdiden** kurulur, v1.5+'da UI eklenir. Diyetisyen 4. rolü ASLA
// eklenmez (00-VISION §5).

enum Role {
  member
  trainer
  gym_owner
}

model User {
  id                String    @id @default(cuid())
  // E.164 normalize edilmiş telefon; "+905551234567".
  // Globally unique — bir hesap = bir telefon. Aynı kişi iki rol istiyorsa
  // ikinci numara kullanır (F1.1 PRD akışı: "Bu telefon zaten kayıtlı, giriş yap").
  phoneE164         String    @unique
  role              Role
  firstName         String
  lastName          String
  profilePhotoUrl   String?

  // PT-spesifik opsiyonel alanlar (member/gym_owner için NULL).
  gymName           String?
  certificateNote   String?

  // KVKK rıza zamanları (audit detayı TASK-1.14'te ayrı tabloda).
  kvkkConsentAt     DateTime?
  healthConsentAt   DateTime?

  // Soft delete + retention (TASK-1.15 job'ı set eder).
  deletedAt         DateTime?
  retentionDeadline DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // İlişkiler — bir kullanıcı birden fazla rolde "bağ" tutabilir,
  // ama application logic role'e göre yalnızca ilgili olanı kullanır.
  memberOfTrainer   TrainerMember[]   @relation("member_relation")
  trainerOfMembers  TrainerMember[]   @relation("trainer_relation")
  ownedTrainers     GymOwnerTrainer[] @relation("owner_relation")
  gymOwnerLinks     GymOwnerTrainer[] @relation("trainer_link")
  // TASK-1.14 — versiyonlu KVKK rıza zinciri (append-only).
  consentRecords    ConsentRecord[]   @relation("user_consent_records")
  // TASK-1.21 — opaque refresh token aileleri (rotate-on-use + replay detection).
  refreshTokens     RefreshToken[]    @relation("user_refresh_tokens")

  @@index([role])
}

// Aktif PT-üye ilişkisi. Üye herhangi bir anda yalnızca BİR aktif PT'ye
// bağlı olabilir (v1). PT değiştirme = mevcut ilişkinin endedAt'ı set
// edilir, yeni satır açılır.
//
// DB-level invariant (aktif ilişki tekliği): migration SQL'inde raw
// partial unique index ile zorlanır —
//   CREATE UNIQUE INDEX ... ON "TrainerMember" ("memberId")
//     WHERE "endedAt" IS NULL;
// Prisma DSL partial unique index üretmediği için raw SQL eklenir.
model TrainerMember {
  id          String    @id @default(cuid())
  trainerId   String
  memberId    String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  trainer     User      @relation("trainer_relation", fields: [trainerId], references: [id])
  member      User      @relation("member_relation", fields: [memberId], references: [id])

  @@index([trainerId])
  @@index([memberId])
  @@index([memberId, endedAt])
}

// Gym Owner ↔ Trainer ilişkisi. v1'de UI yok ve hiç satır oluşmaz; model
// v1.5+'da kullanılacağı için şimdiden tanımlıdır (3 rol mimarisi).
//
// DB-level invariant (aktif ilişki tekliği): migration SQL'inde raw
// partial unique index ile zorlanır —
//   CREATE UNIQUE INDEX ... ON "GymOwnerTrainer" ("trainerId")
//     WHERE "endedAt" IS NULL;
model GymOwnerTrainer {
  id          String    @id @default(cuid())
  gymOwnerId  String
  trainerId   String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  gymOwner    User      @relation("owner_relation", fields: [gymOwnerId], references: [id])
  trainer     User      @relation("trainer_link", fields: [trainerId], references: [id])

  @@index([gymOwnerId])
  @@index([trainerId])
  @@index([trainerId, endedAt])
}

// =====================================================================
// TASK-1.14 — KVKK consent + audit log
// =====================================================================
// KVKK Madde 6 (özel nitelikli sağlık verisi) + Madde 11 (veri sahibi
// hakları) denetlenebilir kayıt gereksinimi:
//   - ConsentRecord: kullanıcı hangi metin sürümünü, ne zaman, nasıl
//     onayladı/geri çekti — versiyonlu, append-only event log.
//     User.kvkkConsentAt / healthConsentAt (TASK-1.13) anlık-durum
//     **denormalized cache**; truth source bu tablodur.
//   - AuditLog: KVKK denetiminde "kim, ne zaman, neyi" gereksinimi için
//     append-only event log. **Ham user ID yazılmaz** — sha256 prefix
//     (12 hex char) ile hash'lenir (broad disclosure önler, correlation
//     için yeterli). metadata Json? alanına **PII YASAK**; helper
//     `logAuditEvent()` zod whitelist ile alanları kısıtlar.

enum ConsentType {
  kvkk_aydinlatma     // zorunlu — hesap açma için
  saglik_verisi       // opsiyonel — ölçüm/yemek için (KVKK Madde 6)
  pazarlama_iletisim  // v1.5 adayı; şimdi tanımlı, kullanım sonra
}

enum ConsentEventType {
  granted
  revoked
  auto_revoked        // 30 gün retention sonrası otomatik (TASK-1.15)
}

enum AuditEventType {
  user_created
  user_login
  user_logout
  user_logout_all
  otp_sent
  otp_verified
  otp_verify_failed
  consent_granted
  consent_revoked
  invitation_created
  invitation_accepted
  member_removed
  refresh_rotated
  refresh_replay_detected
  refresh_expired
  retention_purge
}

// Append-only consent event log. Row UPDATE / DELETE convention olarak
// yasak (code review); geri çekme = yeni `revoked` event'i.
model ConsentRecord {
  id          String           @id @default(cuid())
  userId      String
  consentType ConsentType
  eventType   ConsentEventType
  // Hukuki metin sürümü (tarih-bazlı, örn. "v2026-05-29"). DECISIONS.md
  // — tarih-bazlı tercih edildi: metin tarihsel referans daha doğal.
  textVersion String
  occurredAt  DateTime         @default(now())
  // KVKK denetim bağlamı — bilinçli toplanır; Sentry'ye GÖNDERİLMEZ
  // (memory/kvkk-pii-scrubbing-matrisi.md "IP audit nüansı").
  ipAddress   String?
  userAgent   String?

  user        User             @relation("user_consent_records", fields: [userId], references: [id])

  @@index([userId, consentType])
  @@index([occurredAt])
}

// Append-only audit event log. Ham `userId` YAZILMAZ — sha256 prefix
// hash. metadata Json? PII içermez (helper zod whitelist enforce eder).
model AuditLog {
  id         String         @id @default(cuid())
  userIdHash String
  eventType  AuditEventType
  occurredAt DateTime       @default(now())
  metadata   Json?

  @@index([userIdHash])
  @@index([occurredAt])
  @@index([eventType])
}

// =====================================================================
// TASK-1.17 — Mock SMS provider (dev/staging OTP log)
// =====================================================================
// SMS gönderim katmanı `SmsProvider` interface'i + iki driver ile soyutlanır:
//   - MockSmsProvider (dev/staging) → OTP'yi gerçek SMS yerine bu tabloya yazar.
//   - LiveSmsProvider (Yakın 5) → gerçek provider; MockSmsProvider çağrılmaz,
//     bu tablo **production'da boş kalır** (Live driver row üretmez).
//
// `code` plaintext OTP içerir — bilinçli açık tutulur çünkü tablo yalnızca
// dev/staging'de dolar ve dev OTP lookup endpoint'i (sadece NODE_ENV !=
// production) buradan okur. OTP değeri log/Sentry yoluna `otpCode` alan adıyla
// gider (PII_FIELDS redact eder); ham `code` property'si hiçbir log/serialize
// yüzeyine yazılmaz. Detay: DECISIONS.md "TASK-1.17".
model DevOtpLog {
  id         String    @id @default(cuid())
  phoneE164  String
  code       String
  ttlSec     Int
  createdAt  DateTime  @default(now())
  consumedAt DateTime?

  @@index([phoneE164])
  @@index([createdAt])
}

// =====================================================================
// TASK-1.21 — Refresh token rotation (opaque + rotate-on-use + replay)
// =====================================================================
// "30 gün cihaz hatırlama" (F1.1 oturum yönetimi) + Research §Dikkat #8
// (Fastify refresh rotation resmi recipe yok → bilinçli yazılır + test edilir).
//
// Tasarım kararları (DECISIONS "TASK-1.21"):
//   - **Opaque** token (JWT değil): `crypto.randomBytes(32)` base64url. Token
//     DB'de **YALNIZCA sha256 hash** olarak durur (`tokenHash @unique`) — ham
//     token sadece response'ta gezer. DB dump'ı token'ları açığa çıkarmaz.
//   - **Aile (family):** her ilk login yeni `familyId` başlatır (= bir cihaz).
//     Rotation chain aynı `familyId`'yi taşır; `previousId` zincir takibi.
//   - **rotate-on-use:** her başarılı /auth/refresh eski token'ı
//     `revokedReason:'rotated'` yapar, yeni token verir (chain ilerler).
//   - **Replay detection:** zaten revoke edilmiş token tekrar gelirse o ailenin
//     TÜM aktif token'ları `revokedReason:'replay_detected'` ile iptal edilir
//     (compromise = logout-all benzeri). Concurrent rotation race de aynı
//     compare-and-set (atomik `updateMany ... WHERE revokedAt IS NULL`) ile
//     çözülür: ilk istek kazanır, ikincisi replay sayılır.
//
// `tokenHash @unique` zaten lookup index'i sağlar → ayrı `@@index([tokenHash])`
// gereksizdir (eklenmedi; çift index yazma maliyeti).
model RefreshToken {
  id            String    @id @default(cuid())
  userId        String
  // sha256(token) hex — ham token DB'de yok (dump'ta token açığa çıkmaz).
  tokenHash     String    @unique
  // Rotation chain'i gruplar; bir aile = bir cihaz/oturum.
  familyId      String
  // Önceki refresh token id'si (chain takibi; ilk login'de null).
  previousId    String?
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime
  // revoke durumu: null = aktif. Reason: 'rotated' | 'logout_all' (TASK-1.22)
  // | 'replay_detected'.
  revokedAt     DateTime?
  revokedReason String?
  // userAgent vb. — analytics; PII log/Sentry yoluna gitmez (yalnızca DB).
  deviceInfo    Json?

  user          User      @relation("user_refresh_tokens", fields: [userId], references: [id])

  @@index([userId])
  @@index([familyId])
}
