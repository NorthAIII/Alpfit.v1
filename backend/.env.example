# Alpfit Backend — environment template
#
# Copy to `.env` and fill in real values. `.env` files are gitignored.
# The application validates these on startup (zod) and fails fast if any are
# missing or invalid. See `src/config/env.ts` for the authoritative schema.

# ─── Application ───────────────────────────────────────────────────────────
NODE_ENV=development          # development | staging | production
APP_ENV=local                 # free-form label (local, staging-tr, prod-tr, ...)
PORT=3000

# ─── Logging (optional) ────────────────────────────────────────────────────
# Default: info in production, debug otherwise.
LOG_LEVEL=debug               # fatal | error | warn | info | debug | trace | silent

# ─── Database (TASK-1.03 Prisma setup) ─────────────────────────────────────
# Real Postgres URL will land with Prisma; placeholder keeps the app bootable.
DATABASE_URL=postgresql://placeholder
REDIS_URL=redis://placeholder

# ─── JWT secrets (TASK-1.20 / TASK-1.21) ───────────────────────────────────
# Minimum 32 characters. Generate with: `openssl rand -hex 32`
JWT_ACCESS_SECRET=replace-with-at-least-32-character-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret-too
