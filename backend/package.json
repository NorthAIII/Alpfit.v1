{
  "name": "@alpfit/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm db:generate",
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm db:generate",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "pretypecheck": "pnpm db:generate",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@alpfit/shared": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "fastify": "^5.8.5",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.3"
  }
}
