{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ESNext"],
    "target": "ESNext",
    "allowJs": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["expo/types", "react/canary"],
    "paths": {
      "@shared/*": ["../shared/src/*"]
    }
  },
  "include": [
    "app/**/*",
    "src/**/*",
    "app.config.ts",
    "i18next.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
