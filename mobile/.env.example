# Mobile public env (EXPO_PUBLIC_* — bundle'a girer, sır KOYMA)
# TASK-1.05 baseline; gerçek değerler dev/staging/prod ortamlarına göre değişir.

EXPO_PUBLIC_API_BASE_URL=http://localhost:3711

# Sentry RN crash reporting (TASK-1.12). DSN public (Sentry kabul); secret değil.
# EU Frankfurt residency için DSN host'u `o<orgId>.ingest.de.sentry.io` olmalı.
# Eksikse Sentry init atlanır (degrade mode), app çalışmaya devam eder.
EXPO_PUBLIC_SENTRY_DSN=

# APP_ENV: development | staging | production — Sentry environment tag'i + traces rate.
# Eksikse NODE_ENV → fallback → 'development'.
EXPO_PUBLIC_APP_ENV=development

# Dev OTP otomatik doldurma (TASK-1.29) — yalnızca dev/staging.
# true → OTP ekranında "Dev OTP getir" butonu görünür; GET /internal/dev-otp/:phone
# ile son kodu çeker. __DEV__ build'de zaten açık; production build'de UI gizli +
# endpoint 404 döner.
EXPO_PUBLIC_DEV_OTP_LOOKUP=false

# Internal endpoint bearer token (backend ADMIN_INTERNAL_TOKEN ile aynı değer).
# DEV/STAGING ONLY — EXPO_PUBLIC_* bundle'a girer; production'a GERÇEK token KOYMA.
EXPO_PUBLIC_DEV_OTP_TOKEN=

# Yakın 5'te EAS Build pipeline'ı kendi release tag'ini set eder; manuel için opsiyonel.
# EXPO_PUBLIC_SENTRY_RELEASE=
